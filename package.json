{
  "name": "tinkers",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Web harness for the pi coding agent",
  "engines": {
    "node": ">=22.19.0"
  },
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "vite",
    "build": "vite build",
    "start": "tsx src/server/index.ts",
    "check": "tsc --noEmit",
    "test:unit": "vitest run",
    "test:e2e": "node scripts/e2e-placeholder.mjs"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.79.3",
    "@fastify/static": "^8.0.0",
    "fastify": "^5.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.5.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
